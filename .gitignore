# Keep customer-facing native example source projects even though generic
# React Native generated `android` / `ios` directories are ignored above.
!examples/android/
!examples/android/**
!examples/ios/
!examples/ios/**

# Android example generated files.
examples/android/.gradle/
examples/android/.idea/
examples/android/**/build/
examples/android/**/*.iml
examples/android/local.properties

# iOS example generated files.
examples/ios/Pods/
examples/ios/Podfile.lock
examples/ios/*.xcworkspace/
examples/ios/DerivedData/
examples/ios/build/
examples/ios/**/*.xcuserstate
examples/ios/**/xcuserdata/
examples/ios/**/project.xcworkspace/
